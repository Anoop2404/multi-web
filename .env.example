APP_NAME="Sahodaya Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://sahodaya.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=central
DB_DRIVER=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=sahodaya
DB_USERNAME=sahodaya
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3

# AWS S3 (production). For local MinIO, set AWS_ENDPOINT and AWS_USE_PATH_STYLE_ENDPOINT=true.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_ENDPOINT=
# All uploads live under this S3 prefix (e.g. domains/logos/{tenant-id}/logo.png)
AWS_ROOT_PREFIX=domains
# Optional CDN/base URL, e.g. https://neoo-s3-bucket.s3.ap-south-1.amazonaws.com
AWS_URL=

# Override upload disk for private files (payment proofs). Defaults to FILESYSTEM_DISK.
# UPLOAD_DISK=shared
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Zoho Mail — all notifications (school apply, email verify, membership, enquiries).
# Docs: https://www.zoho.com/mail/help/zoho-smtp.html
# Local dev: MAIL_MAILER=log (writes to storage/logs). Production: MAIL_MAILER=smtp.
# India: smtp.zoho.in | Global: smtp.zoho.com | Paid org domain: smtppro.zoho.com
# Port 587 uses STARTTLS (scheme auto). Port 465 uses implicit SSL (smtps).
# MAIL_USERNAME = full Zoho mailbox. MAIL_PASSWORD = app-specific password if 2FA is on.
# MAIL_FROM_ADDRESS must match the Zoho account or a verified alias.
MAIL_MAILER=log
MAIL_HOST=smtp.zoho.in
MAIL_PORT=587
MAIL_SCHEME=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# UPLOAD_DISK=shared

VITE_APP_NAME="${APP_NAME}"

# ── Domains ──────────────────────────────────────────────────────────────────
# Superadmin panel (central host only):
#   Production: CENTRAL_DOMAIN=superadmin.com  →  https://superadmin.com/admin
#   Local dev:  CENTRAL_DOMAIN=superadmin.test →  http://superadmin.test:8000/admin
CENTRAL_DOMAIN=superadmin.test
APP_URL=http://superadmin.test

# Optional platform domain for subdomain tenants (schoolname.{TENANT_BASE_DOMAIN})
TENANT_BASE_DOMAIN=sahodaya.test

# Each Sahodaya uses a dedicated PostgreSQL DB — create it manually, set the name in Superadmin, then run migrations.
# Set false for single-DB local/tests.
TENANCY_DATABASE_PER_SAHODAYA=true
# Local dev: auto-create and migrate missing Sahodaya DBs on first request (defaults true when APP_ENV=local).
TENANCY_AUTO_CREATE_DATABASE=true

# Sahodaya custom domains are set per tenant in Superadmin → Tenants, e.g.:
#   malappuramsahodaya.com  (local demo: malappuramsahodaya.test)
# Point DNS A/CNAME for each custom domain to your app server.
# Set true to enable public websites, site builder, and CMS menus
WEBSITE_ENABLED=false
