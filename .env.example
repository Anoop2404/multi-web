APP_NAME="Sahodaya Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://sahodaya.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=sahodaya
DB_USERNAME=sahodaya
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@sahodaya.test"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=sahodaya
AWS_SECRET_ACCESS_KEY=sahodaya_secret
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=sahodaya
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=http://minio:9000

MINIO_ROOT_USER=sahodaya
MINIO_ROOT_PASSWORD=sahodaya_secret
MINIO_BUCKET=sahodaya

VITE_APP_NAME="${APP_NAME}"
